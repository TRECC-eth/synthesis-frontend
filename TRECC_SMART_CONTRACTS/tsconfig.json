{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./hardhat.config.ts", 
    "./ignition/**/*.ts", 
    "./scripts/**/*.ts", 
    "./test/**/*.ts"
  ]
}